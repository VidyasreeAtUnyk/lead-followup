{
  "name": "lead-followup",
  "version": "1.0.0",
  "private": true,
  "description": "Agentic real estate lead follow-up system with human-in-the-loop approval",
  "type": "module",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "cli": "tsx src/cli/index.ts",
    "seed": "tsx src/db/seed.ts",
    "reset-db": "tsx src/db/reset.ts",
    "process": "tsx src/agent/runQueue.ts",
    "evals": "tsx src/evals/run.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "openai": "^4.68.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
