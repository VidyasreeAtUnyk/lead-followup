OPENAI_API_KEY=sk-...
# Optional, defaults to gpt-5.4-mini
OPENAI_MODEL=gpt-5.4-mini

# --- experiment/gemini-provider branch only, not used on main ---
# Set MODEL_PROVIDER=gemini to route runAgentForLead through Gemini instead
# of OpenAI (src/agent/loopGemini.ts). Requires GEMINI_API_KEY; OPENAI_API_KEY
# is not needed in that case.
MODEL_PROVIDER=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
